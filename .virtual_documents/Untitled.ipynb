import numpy as np  
import pandas as pd  
import matplotlib.pyplot as plt  
import seaborn as sns 
import warnings

warnings.filterwarnings('ignore')


df = pd.read_csv('ford.csv')


df


df.shape


df.info()


df.describe()


sns.histplot(x= df['price'], bins=50, kde =True)


sns.boxplot(data = df, x='engineSize', y='price')


sns.boxplot(data = df, x='year', y='price')
plt.xticks(rotation = 90)


df.columns


sns.boxplot(data = df, x='fuelType', y='price')


sns.boxplot(data = df, x='transmission', y='price')


sns.boxplot(data = df, x='tax', y='price')
plt.xticks(rotation = 90)


sns.boxplot(data = df, x='model', y='price')
plt.xticks(rotation=90)


sns.heatmap(df.corr(numeric_only=True), annot=True)





df.columns


X = df.drop(columns='price', axis=1)
y=df['price']


X


X_one_lable = pd.get_dummies(X, columns=['model', 'transmission', 'fuelType'], drop_first=True)


X_one_lable


X_one_lable = X_one_lable.astype(int)


X_one_lable


from sklearn.preprocessing import StandardScaler
scaler = StandardScaler()


numeric_col = ['year',	'mileage',	'tax'	,'mpg',	'engineSize']
X_one_lable[numeric_col] = scaler.fit_transform(X_one_lable[numeric_col])


X_one_lable


from sklearn.linear_model import LinearRegression
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score


X_train, X_test, y_train, y_test = train_test_split(X_one_lable, y, test_size=0.33, random_state=42)


model = LinearRegression()
model.fit(X_train, y_train)


y_pred = model.predict(X_test)


from sklearn.metrics import r2_score

# R2 score
r2 = r2_score(y_test, y_pred)

n = len(y_test)        # number of samples
k = X_test.shape[1]   # number of features

# Adjusted R2
adjusted_r2 = 1 - ((1 - r2) * (n - 1) / (n - k - 1))

print("R2 Score:", r2)
print("Adjusted R2 Score:", adjusted_r2)


import pickle

# Save model
pickle.dump(model, open("car_price_model.pkl", "wb"))

# If you used scaler/encoder
pickle.dump(scaler, open("scaler.pkl", "wb"))


